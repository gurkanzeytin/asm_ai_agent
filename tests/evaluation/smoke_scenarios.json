    {
      "id": "03_monthly_trend",
      "title": "Aylık Eğilim",
      "category": "Trend",
      "question": "Son 6 aydaki randevu eğilimini kısaca yorumla.",
      "session_group": "monthly_trend",
      "expected_outcome": "EXECUTE_SQL",
      "expected_analysis_type": "trend|time_series",
      "expected_provider": "ollama|local_llm",
      "expected_model_contains": "qwen",
      "expected_metrics": ["monthly_appointment_count"],
      "expected_dimensions": [],
      "expected_context_applied": false,
      "expected_sql_contains": ["GROUP BY"],
      "forbidden_sql_contains": [],
      "expected_ui_text_contains": [],
      "forbidden_ui_text_contains": ["monthly_appointment_count"],
      "max_duration_seconds": 45,
      "notes": "Tamamlanmamış dönem varsa sınırlama görünmeli; trend kuralları çelişmemelidir.",
      "assertions": [
        {"kind": "equals_path", "path": "resolved_time_grain", "expected": "month", "severity": "MAJOR", "message": "Aylık zaman kırılımı bekleniyor."},
        {"kind": "no_contradictory_trend_rules", "expected": true, "severity": "CRITICAL", "message": "Birbiriyle çelişen trend kuralları bulundu."},
        {"kind": "trend_language_consistency", "expected": ["monthly_appointment_count", "appointment_count"], "severity": "CRITICAL", "message": "Raporun sürekli yükseliş iddiası dönem değerleriyle çelişiyor."},
        {"kind": "partial_period_disclosed", "expected": true, "severity": "MINOR", "message": "Kısmi dönem sınırlaması raporda açıklanmadı."}
      ]
    },
