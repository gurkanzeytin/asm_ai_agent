    {
      "id": "01_basic_distribution",
      "title": "Randevu Durumu Dağılımı",
      "category": "Dağılım",
      "question": "Randevu durumlarının dağılımını göster.",
      "session_group": "basic_distribution",
      "expected_outcome": "EXECUTE_SQL",
