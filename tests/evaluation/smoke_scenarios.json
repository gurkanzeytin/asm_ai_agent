      "expected_metrics": ["appointment_count"],
      "expected_dimensions": ["status"],
      "expected_context_applied": false,
      "expected_sql_contains": ["GROUP BY RandevuDurumu"],
      "forbidden_sql_contains": ["WHERE RandevuDurumu ="],
