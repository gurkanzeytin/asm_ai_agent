# Application Configurations
APP_NAME="ASM AI Agent"
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
INTENT_CONFIDENCE_THRESHOLD=0.6

# API Routing & CORS
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Database configurations — Microsoft SQL Server (the only runtime database)
#
# Windows Authentication is used: the connection runs under the Windows identity of
# the process that starts the backend. NEVER put a username or password here.
# Requires "Microsoft ODBC Driver 18 for SQL Server" installed on the host.
DB_SERVER=ASMPSHISBCK2
DB_DATABASE=PusulaComed
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_TRUSTED_CONNECTION=true
DB_TRUST_SERVER_CERTIFICATE=true
# Optional explicit override (mssql+aioodbc only); normally constructed from DB_* above.
# DATABASE_URL=mssql+aioodbc:///?odbc_connect=<url-encoded ODBC connection string>
SQL_DIALECT=tsql
DATABASE_SCHEMA=dbo
# Comma-separated whitelist: generated SQL may ONLY read from these objects.
DATABASE_ALLOWED_OBJECTS=dbo.vw_RandevuRaporu
DATABASE_POOL_SIZE=10
DATABASE_ECHO=false
DATABASE_CONNECT_TIMEOUT=15
DATABASE_QUERY_TIMEOUT=60
DATABASE_MAX_PAGE_SIZE=1000

# LLM configuration settings
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
# Model selection: use qwen2.5:3b for faster development inference, qwen3:8b for production quality.
OLLAMA_MODEL=qwen3:8b
# Dedicated embedding model. Install locally with: ollama pull nomic-embed-text
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Increase OLLAMA_TIMEOUT for CPU-based inference (qwen3:8b on CPU needs 60–180s).
# Use httpx split timeouts: connect=10s fast-fail, read=OLLAMA_TIMEOUT for inference wait.
OLLAMA_TIMEOUT=300.0
# LLM_RETRY_COUNT: keep low (1) to avoid multiplying timeout by retry count on failure.
LLM_RETRY_COUNT=1

# Gemini configurations
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# NVIDIA NIM (OpenAI-compatible) configurations — remote provider, used by the
# insight-routing remote leg (INSIGHT_REMOTE_PROVIDER) and whenever
# LLM_PROVIDER=nvidia. Never send raw patient rows to this provider; see
# backend/app/llm/remote_policy.py for the enforced remote data policy.
# Generate a key at https://build.nvidia.com and put it ONLY in your local .env file
# (never here — this is a shared example file, never a real credential).
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Verified working model for complex insight generation (~17s smoke-test latency).
# deepseek-ai/deepseek-v4-pro currently 404s on NVIDIA's endpoint; openai/gpt-oss-120b
# and z-ai/glm-5.2 work but are too slow for active routing — do not default to either.
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b
NVIDIA_TIMEOUT_SECONDS=90
NVIDIA_MAX_RETRIES=1
NVIDIA_MAX_TOKENS=2048
NVIDIA_TEMPERATURE=0.1
NVIDIA_TOP_P=0.95
NVIDIA_THINKING=false

# Insight generation routing — deterministic templates / local Ollama (qwen3) /
# remote NVIDIA (Nemotron). Reuses the OLLAMA_*/NVIDIA_* settings above; these
# only control the routing decision, never a separate credential set. See
# backend/app/insights/routing.py for the complexity-scoring rules.
INSIGHT_ROUTING_ENABLED=true
INSIGHT_DETERMINISTIC_ENABLED=true
INSIGHT_LOCAL_PROVIDER=ollama
INSIGHT_REMOTE_PROVIDER=nvidia
INSIGHT_REMOTE_COMPLEXITY_THRESHOLD=3

# Database Intelligence settings
SCHEMA_CACHE_ENABLED=true
SCHEMA_CACHE_TTL=3600.0
AUTO_REFRESH_SCHEMA=true
# Schema context limits: reduce to shrink LLM prompt size during fallback retrieval.
# PK and FK columns are always preserved regardless of SCHEMA_MAX_COLUMNS.
SCHEMA_MAX_TABLES=5
SCHEMA_MAX_COLUMNS=15

# Logging level
LOG_LEVEL=INFO
