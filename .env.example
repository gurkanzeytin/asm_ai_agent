# Application Configurations
APP_NAME="ASM AI Agent"
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
INTENT_CONFIDENCE_THRESHOLD=0.6

# API Routing & CORS
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Database configurations
#
# --- SQLite local development ---
# DATABASE_URL=sqlite+aiosqlite:///./data/hospital_demo.db
# SQL_DIALECT=sqlite
#
# --- SQL Server with Windows Authentication (requires Microsoft ODBC Driver 18) ---
# Integrated security uses the Windows identity of the process running the backend;
# never put a username or password in the URL.
DATABASE_URL=mssql+aioodbc://@ASMPSHISBCK2/PusulaComed?driver=ODBC+Driver+18+for+SQL+Server&trusted_connection=yes&TrustServerCertificate=yes
SQL_DIALECT=tsql
DATABASE_SCHEMA=dbo
# Comma-separated whitelist of queryable objects; leave empty for unrestricted local SQLite.
DATABASE_ALLOWED_OBJECTS=dbo.vw_RandevuRaporu
DATABASE_POOL_SIZE=10
DATABASE_ECHO=false
DATABASE_CONNECT_TIMEOUT=15
DATABASE_QUERY_TIMEOUT=30
DATABASE_MAX_PAGE_SIZE=1000

# LLM configuration settings
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
# Model selection: use qwen2.5:3b for faster development inference, qwen3:8b for production quality.
OLLAMA_MODEL=qwen3:8b
# Dedicated embedding model. Install locally with: ollama pull nomic-embed-text
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Increase OLLAMA_TIMEOUT for CPU-based inference (qwen3:8b on CPU needs 60–180s).
# Use httpx split timeouts: connect=10s fast-fail, read=OLLAMA_TIMEOUT for inference wait.
OLLAMA_TIMEOUT=300.0
# LLM_RETRY_COUNT: keep low (1) to avoid multiplying timeout by retry count on failure.
LLM_RETRY_COUNT=1

# Gemini configurations
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Database Intelligence settings
SCHEMA_CACHE_ENABLED=true
SCHEMA_CACHE_TTL=3600.0
AUTO_REFRESH_SCHEMA=true
# Schema context limits: reduce to shrink LLM prompt size during fallback retrieval.
# PK and FK columns are always preserved regardless of SCHEMA_MAX_COLUMNS.
SCHEMA_MAX_TABLES=5
SCHEMA_MAX_COLUMNS=15

# Logging level
LOG_LEVEL=INFO
