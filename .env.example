# Application Configurations
APP_NAME="ASM AI Agent"
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# API Routing & CORS
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000

# Database configurations
# For SQLite local dev: sqlite+aiosqlite:///./sql_app.db
# For PostgreSQL: postgresql+asyncpg://postgres:postgres@localhost:5432/reporting_agent
DATABASE_URL=sqlite+aiosqlite:///./sql_app.db
DATABASE_POOL_SIZE=10
DATABASE_ECHO=false

# Ollama local AI server integration settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Logging level
LOG_LEVEL=INFO
